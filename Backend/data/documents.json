          "type": "h1",
          "content": "Intro to Algorithms — My Notes"
        },
        {
          "id": "78e28258-1c9d-4a89-886b-39bf0eeda703",
          "type": "callout",
          "content": "This is your personal fork. Edit freely — nothing here affects the master document until you submit a merge request.",
          "meta": {
